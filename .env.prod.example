# MauriPay backend production secrets — copy to .env.prod and fill in. DO NOT COMMIT .env.prod
DB_PASSWORD=                 # strong random (e.g. openssl rand -hex 24)
APP_DEV_SEED=true            # seeds the demo merchant Dawaii pays against
APP_DEV_MERCHANT_KEY=        # strong random; must equal Dawaii's MAURIPAY_API_KEY
